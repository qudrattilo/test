        { text: "‘Symmetric encryption’ da nimadan foydalaniladi?", options: ["Bir kalit shifrlash va ochish", "Ikki kalit", "Hash funksiyasi", "Faol kalit almashinuvi"], correct: 0 },
        { text: "‘Ajax’ texnologiyasi asosan nima qiladi?", options: ["Veb-sahifani qayta yuklamasdan ma'lumot almashish", "Server tomoni mantiq", "CSS animatsiya", "SQL so'rovlar"], correct: 0 },
        { text: "‘Bash’ nima?", options: ["Unix shell va buyruq tili", "Dasturlash tili", "Ma'lumotlar bazasi", "Office dasturi"], correct: 0 },
        { text: "‘CAP theorem’ qaysi sohaga tegishli?", options: ["Distributed ma'lumotlar bazalari", "Algoritmlar nazariyasi", "Tarmoq protokollari", "Sun'iy intellekt"], correct: 0 },
        { text: "‘Scrum’ metodologiyasi qayerda qo‘llaniladi?", options: ["Loyihalarni boshqarish (Agile)", "Dasturiy ta'minot testlash", "Ma'lumotlar tahlili", "Dizayn"], correct: 0 },
        { text: "‘Ransomware’ nima qiladi?", options: ["Ma'lumotlarni shifrlab, to'lov talab qiladi", "Tizimni tezlashtiradi", "Veb-sayt yaratadi", "Skrinshot oladi"], correct: 0 },
        { text: "‘Latency’ tarmoqda nimani anglatadi?", options: ["Ma'lumot uzatish kechikishi", "O‘tkazuvchanlik", "Xatolik darajasi", "Sig‘imi"], correct: 0 },
        { text: "‘GraphQL’ nima uchun ishlatiladi?", options: ["API uchun so‘rov tili", "Grafik render", "Ma'lumotlar bazasi", "Frontend framework"], correct: 0 },
        { text: "‘Responsive web design’ maqsadi?", options: ["Turli qurilmalarga moslashuvchan sahifa", "Tezkor yuklanish", "Kengaytirilgan xavfsizlik", "Server mustaqillik"], correct: 0 },
        { text: "‘Deepfake’ texnologiyasi nimaga asoslangan?", options: ["Sun’iy intellekt va neyron tarmoqlar", "Oddiy video muharrir", "3D modellashtirish", "Blokcheyn"], correct: 0 },
        { text: "‘Chipset’ qaysi komponentlarni boshqaradi?", options: ["CPU va periferiya o‘rtasidagi aloqani", "Faqat xotira", "Faqat grafik", "Tarmoq kartasi"], correct: 0 },
        { text: "JSON ma'lumot formati asosan qayerda ishlatiladi?", options: ["API va ma'lumot almashishda", "Tasvirlar", "Ovoz fayllari", "Arxivlash"], correct: 0 },
    ];

    // To‘liq 100 ta ekanligiga ishonch hosil qilish (agar 100 dan kam bo‘lsa to‘ldirish, aslida biz 100 ta yaratdik)
    // Jami 100 ta bo‘lishini tekshirish
    console.assert(QUESTION_BANK.length === 100, "Savollar soni 100 ta bo'lishi kerak, hozir: " + QUESTION_BANK.length);

    // Global o‘zgaruvchilar
    let currentQuestions = [];      // {qData, originalIndex, userAnswer(null yoki number)}
    let rendered = false;

    // Tasodifiy 25 ta savol tanlash (takrorlanmasdan)
    function selectRandomQuestions() {
        const shuffled = [...QUESTION_BANK];
        for (let i = shuffled.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
        }
        const selected = shuffled.slice(0, 25);
        return selected.map((q, idx) => ({
            qData: q,
            originalId: idx,
            userAnswer: null
        }));
    }

    // Testni render qilish
    function renderTest() {
        const quizContainer = document.getElementById('quiz');
        if (!quizContainer) return;
        if (!currentQuestions.length) {
            currentQuestions = selectRandomQuestions();
        }
        let html = '';
        currentQuestions.forEach((item, idx) => {
            const q = item.qData;
            const qNumber = idx + 1;
            html += `
                <div class="question-card" data-qidx="${idx}">
                    <div class="question-text">${qNumber}. ${escapeHtml(q.text)}</div>
                    <div class="options">
            `;
            q.options.forEach((opt, optIdx) => {
                const isChecked = (item.userAnswer === optIdx);
                const checkedAttr = isChecked ? 'checked' : '';
                html += `
                    <div class="option">
                        <input type="radio" name="q${idx}" value="${optIdx}" id="q${idx}_opt${optIdx}" ${checkedAttr}>
                        <label for="q${idx}_opt${optIdx}">${String.fromCharCode(65+optIdx)}. ${escapeHtml(opt)}</label>
                    </div>
                `;
            });
            html += `</div></div>`;
        });
        quizContainer.innerHTML = html;
        // Radio o‘zgarishlarni tracking
        for (let i = 0; i < currentQuestions.length; i++) {
            const radios = document.querySelectorAll(`input[name="q${i}"]`);
            radios.forEach(radio => {
                radio.addEventListener('change', (e) => {
                    const selectedVal = parseInt(e.target.value);
                    currentQuestions[i].userAnswer = selectedVal;
                });
            });
        }
        // natijalar panelini yashirish
        const resultDiv = document.getElementById('result');
        if (resultDiv) resultDiv.style.display = 'none';
    }

    // XTML special chars himoya
    function escapeHtml(str) {
        return str.replace(/[&<>]/g, function(m) {
            if (m === '&') return '&amp;';
            if (m === '<') return '&lt;';
            if (m === '>') return '&gt;';
            return m;
        }).replace(/[\uD800-\uDBFF][\uDC00-\uDFFF]/g, function(c) {
            return c;
        });
    }

    // Baholash va natijalarni chiqarish
    function evaluateAndShow() {
        if (!currentQuestions.length) {
            currentQuestions = selectRandomQuestions();
            renderTest();
        }
        let totalCorrect = 0;
        const detailedResults = [];
        for (let i = 0; i < currentQuestions.length; i++) {
            const item = currentQuestions[i];
            const correctIdx = item.qData.correct;
            const userAns = item.userAnswer;
            const isCorrect = (userAns !== null && userAns === correctIdx);
            if (isCorrect) totalCorrect++;
            detailedResults.push({
                questionText: item.qData.text,
                userAnswer: userAns,
                correctAnswer: correctIdx,
                options: item.qData.options,
                isCorrect: isCorrect,
                correctAnswerText: item.qData.options[correctIdx]
            });
        }
        const score = totalCorrect * 4;  // 4 ball har bir to‘g‘ri javob
        const resultDiv = document.getElementById('result');
        if (!resultDiv) return;
        
        let feedbackHtml = `<div style="margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
            <div><span class="score-badge">🏆 ${score} / 100 ball</span></div>
            <div><strong>✅ To‘g‘ri javoblar:</strong> ${totalCorrect} / 25 &nbsp;| &nbsp;⭐ Har bir to‘g‘ri 4 ball</div>
        </div><hr>`;
        
        feedbackHtml += `<div style="max-height: 500px; overflow-y: auto; padding-right: 8px;">`;
        detailedResults.forEach((res, idx) => {
            const statusClass = res.isCorrect ? 'correct-feedback' : 'wrong-feedback';
            const statusIcon = res.isCorrect ? '✔️' : '❌';
            const userLetter = (res.userAnswer !== null && res.userAnswer >=0 && res.userAnswer <=3) ? String.fromCharCode(65+res.userAnswer) : '❓';
            const correctLetter = String.fromCharCode(65+res.correctAnswer);
            feedbackHtml += `
                <div class="feedback-item ${statusClass}" style="margin-bottom: 12px;">
                    <div style="font-weight: 700;">${idx+1}. ${escapeHtml(res.questionText)}</div>
                    <div style="margin-top: 6px; font-size:0.9rem;">${statusIcon} Sizning javob: ${userLetter !== '❓' ? userLetter+") "+escapeHtml(res.options[res.userAnswer]) : "Javob tanlanmagan"}</div>
                    <div style="color: #1e6f3f; font-size:0.9rem;">✅ To‘g‘ri javob: ${correctLetter}) ${escapeHtml(res.correctAnswerText)}</div>
                </div>
            `;
        });
        feedbackHtml += `</div><div style="margin-top: 20px; text-align: center; font-size:0.9rem;">📌 Yana yangi test olish uchun "Yangi test variantini olish" tugmasini bosing.</div>`;
        resultDiv.innerHTML = feedbackHtml;
        resultDiv.style.display = 'block';
        // Natijalar ko‘rinishi uchun smooth scroll
        resultDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Yangi test to‘plami (25 tasi)
    function loadNewVariant() {
        currentQuestions = selectRandomQuestions();
        renderTest();
        const resultDiv = document.getElementById('result');
        if (resultDiv) resultDiv.style.display = 'none';
    }

    // Sahifa yuklanganda
    document.addEventListener('DOMContentLoaded', () => {
        currentQuestions = selectRandomQuestions();
        renderTest();
        const submitBtn = document.getElementById('submitBtn');
        const newSetBtn = document.getElementById('newSetBtn');
        if (submitBtn) submitBtn.addEventListener('click', evaluateAndShow);
        if (newSetBtn) newSetBtn.addEventListener('click', loadNewVariant);
    });
</script>
</body>
</html>
