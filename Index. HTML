        </div>
        <div id="result" class="result-panel" style="display: none;">
            <!-- Natijalar shu yerda ko'rinadi -->
        </div>
    </div>
    <footer>
        🧪 Informatika (yuqori sinflar uchun) • 100 ta savol omboridan 25 tasi tasodifiy • 100 ballik tizim
    </footer>
</div>

